# --- Required API Keys ---

# OpenAI API key for LLM reasoning
OPENAI_API_KEY=your_openai_api_key_here

# Exa API key for neural search results
EXA_API_KEY=your_exa_api_key_here

# --- Debugging and Tracing ---

# LangSmith project name and API key (required for LangGraph Studio)
LANGSMITH_PROJECT=deep-research
# LANGSMITH_API_KEY=your_langsmith_api_key_here

# --- Research Loop Tuning ---

# Hard limit for research iterations (default: 15)
# RESEARCH_MAX_ITERATIONS=15

# Maximum parallel workers for batch research (default: 10)
# RESEARCH_MAX_CONCURRENT_WORKERS=10

# Base VFS path for thread-specific findings (default: ./vfs)
# RESEARCH_VFS_PATH=./vfs

# --- Model Selection and Reasoning ---

# Intake Model (default: gpt-5-nano)
# RESEARCH_INTAKE_MODEL=gpt-5-nano
# RESEARCH_INTAKE_REASONING=low

# Supervisor Model (default: o3-mini)
# RESEARCH_SUPERVISOR_MODEL=o3-mini
# RESEARCH_SUPERVISOR_REASONING=high

# Worker Model (default: gpt-5-nano)
# RESEARCH_WORKER_MODEL=gpt-5-nano
# RESEARCH_WORKER_REASONING=low

# Final Report Model (default: o3-mini)
# RESEARCH_REPORT_MODEL=o3-mini
# RESEARCH_REPORT_REASONING=high

# --- Search Tuning ---

# Exa search results per query (default: 8)
# EXA_NUM_RESULTS=8

# Maximum characters of full text to record to disk per result (default: 8000)
# EXA_MAX_CHARACTERS=8000

# Number of search highlights per result (default: 5)
# EXA_NUM_SENTENCES=5
